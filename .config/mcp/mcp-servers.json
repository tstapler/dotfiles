{
  "mcpServers": {
    "brave-search": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-brave-search"
      ],
      "_fork": "exception: official @modelcontextprotocol Anthropic-maintained package",
      "env": {
        "BRAVE_API_KEY": "${BRAVE_API_KEY}"
      }
    },
    "read-website-fast": {
      "command": "npm",
      "args": [
        "exec",
        "--yes",
        "--",
        "git+https://github.com/tstapler/mcp-read-website-fast"
      ],
      "_fork": "https://github.com/tstapler/mcp-read-website-fast",
      "env": {}
    },
    "website-downloader": {
      "command": "uvx",
      "args": [
        "--from",
        "git+https://github.com/tstapler/mcp-website-downloader.git",
        "mcp-website-downloader"
      ],
      "_fork": "https://github.com/tstapler/mcp-website-downloader",
      "env": {}
    },
    "docs": {
      "command": "npm",
      "args": [
        "exec",
        "--yes",
        "--",
        "git+https://github.com/tstapler/docs-mcp-server"
      ],
      "_fork": "https://github.com/tstapler/docs-mcp-server",
      "env": {
        "DOCS_MCP_STORE_PATH": "~/.local/share/docs-mcp-server"
      }
    },
    "playwright": {
      "command": "npx",
      "args": [
        "-y",
        "@playwright/mcp@latest"
      ],
      "env": {}
    }
  }
}
