[init]
	templatedir = ~/.gittemplates
	defaultBranch = main

[core]
	editor = vim
	excludesfile = ~/.gitignore
	symlinks = true
	autocrlf = input

[web]
	browser = google-chrome-stable

[push]
	default = matching

[color]
	ui = auto

[diff]
	tool = meld

[hub]
	protocol = ssh

[user]
	name = Tyler Stapler
	email = tystapler@gmail.com

[alias]
	meld = !git difftool -t meld --dir-diff

[mergetool "meld"]
    cmd = meld "$LOCAL" "$MERGED" "$REMOTE" --output "$MERGED"

[rebase]
	instructionFormat = (%an <%ae>) %s

[http]
	cookiefile = ~/.gitcookies
[pull]
	rebase = true

[net]
git-fetch-with-cli = true

[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
[rerere]
	enabled = true
[credential "https://github.com"]
	helper = 
	helper = !/opt/homebrew/bin/gh auth git-credential
[credential "https://gist.github.com"]
	helper = 
	helper = !/opt/homebrew/bin/gh auth git-credential
# Work identity (name/email) is applied to repos under the work projects
# directory via this include. The fbg role writes ~/.gitconfig.fbg on work
# machines; on personal machines the file is absent and this is a no-op.
[includeIf "gitdir:~/WorkProjects/"]
	path = ~/.gitconfig.fbg
[credential]
	helper = !gh auth git-credential
[machete]
	squashMergeDetection = simple
