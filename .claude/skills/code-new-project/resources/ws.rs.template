//! Bidirectional streaming transport over WebSocket.
//!
//! Why this exists instead of streaming everything through Connect-RPC:
//! as of early 2026 no stable browser ships true HTTP/2 duplex fetch
//! (`duplex: "full"`), so a browser client cannot both send and receive on
//! one Connect/gRPC-Web stream concurrently. Unary and server-streaming
//! RPCs don't need this and should go through Connect-RPC instead (see
//! CONNECT_RPC_NOTE.md) — reserve this transport for genuinely
//! bidirectional exchanges (chat, live collaboration, etc.).
//!
//! Messages are framed as binary-encoded protobuf (`ChatEnvelope` from
//! greet.proto) rather than JSON, so the same generated types can be
//! shared conceptually with the Connect-RPC side even though this path
//! doesn't go through Connect's transport abstraction.

use axum::extract::ws::{Message, WebSocket, WebSocketUpgrade};
use axum::response::IntoResponse;
use futures::{SinkExt, StreamExt};
use prost::Message as _;

pub mod pb {
    include!(concat!(env!("OUT_DIR"), "/greet.v1.rs"));
}

pub async fn ws_handler(ws: WebSocketUpgrade) -> impl IntoResponse {
    ws.on_upgrade(handle_socket)
}

async fn handle_socket(socket: WebSocket) {
    let (mut sender, mut receiver) = socket.split();

    while let Some(Ok(msg)) = receiver.next().await {
        let Message::Binary(bytes) = msg else {
            continue; // ignore ping/pong/text/close — client should send binary protobuf frames
        };

        let envelope = match pb::ChatEnvelope::decode(bytes.as_ref()) {
            Ok(e) => e,
            Err(err) => {
                tracing::warn!(?err, "dropping malformed ws frame");
                continue;
            }
        };

        // TODO: replace with real handling — this just echoes back.
        if let Some(pb::chat_envelope::Payload::Message(m)) = envelope.payload {
            let reply = pb::ChatEnvelope {
                payload: Some(pb::chat_envelope::Payload::Message(pb::ChatMessage {
                    from: "server".into(),
                    body: format!("echo: {}", m.body),
                })),
            };
            let mut buf = Vec::new();
            if reply.encode(&mut buf).is_ok() {
                let _ = sender.send(Message::Binary(buf.into())).await;
            }
        }
    }
}
