# Copy to .env (gitignored) and fill in. This is the canonical list of
# what the app/IaC need — see reference.md's secrets section for why
# direnv + .env is the baseline (upgrade to `op run` + this file as an
# `.env.tpl` of `op://` references if you use 1Password).

# Neon Local (docker-compose.yml) — connects to a REAL ephemeral Neon
# branch, not an offline emulator. Get these from the Neon console.
NEON_API_KEY=
NEON_PROJECT_ID=
NEON_PARENT_BRANCH_ID=

# App runtime — Neon Local proxies this locally; in CI/prod this comes
# from Secret Manager / the Neon branch's own connection string instead.
DATABASE_URL=postgres://neon:npg@localhost:5432/main

# OpenTofu (also needed in GitHub Actions secrets for CI-driven apply)
CLOUDFLARE_API_TOKEN=
# NEON_API_KEY reused from above

# R2 (if the app talks to R2 directly rather than only through OpenTofu)
CLOUDFLARE_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
